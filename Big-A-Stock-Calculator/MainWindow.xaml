<Window x:Class="Big_A_Stock_Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Big_A_Stock_Calculator"
        mc:Ignorable="d"
        Title="A股做T保本计算器" Height="700" Width="850" WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- 一、参数设置区 -->
        <GroupBox Header="费率设置 (系统默认参数)" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="佣金费率 (默认为万分之4.3):" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="CommissionRateTextBox" Text="0.00043" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="印花税率 (默认为万分之5):" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="StampDutyRateTextBox" Text="0.0005" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                
                <TextBlock Text="是否免五 (不足5元不按5元收):" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <CheckBox x:Name="IsFree5CheckBox" IsChecked="True" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 涨跌停预测区 -->
        <GroupBox Header="涨跌停预测" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" Padding="10">
            <StackPanel>
                 <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                     <TextBlock Text="昨日收盘价(元):" VerticalAlignment="Center" Margin="0,0,10,0"/>
                     <TextBox x:Name="YesterdayCloseTextBox" Width="80" TextChanged="YesterdayClose_Update" VerticalContentAlignment="Center"/>
                     <TextBlock Text="板块:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                     <ComboBox x:Name="BoardTypeComboBox" SelectionChanged="YesterdayClose_Update" SelectedIndex="0" VerticalContentAlignment="Center">
                         <ComboBoxItem Content="主板(10%)"/>
                         <ComboBoxItem Content="创业/科创(20%)"/>
                     </ComboBox>
                 </StackPanel>
                 <StackPanel Orientation="Horizontal">
                     <TextBlock Text="涨停价:" Foreground="#E51400" Margin="0,0,5,0"/>
                     <TextBlock x:Name="LimitUpTextBlock" Text="---" FontWeight="Bold" Foreground="#E51400" Width="60"/>
                     <TextBlock Text="跌停价:" Foreground="#008A00" Margin="10,0,5,0"/>
                     <TextBlock x:Name="LimitDownTextBlock" Text="---" FontWeight="Bold" Foreground="#008A00"/>
                 </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- 二、首笔交易输入区 -->
        <GroupBox Header="首笔交易信息" Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="操作类型:" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <ComboBox x:Name="OperationModeComboBox" Grid.Column="1" Margin="0,0,0,5" SelectedIndex="0">
                    <ComboBoxItem Content="先买后卖（正T）"/>
                    <ComboBoxItem Content="先卖后买（倒T）"/>
                </ComboBox>

                <TextBlock Text="交易单价 (元):" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="PriceTextBox" Text="20.20" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="交易股数 (股):" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBox x:Name="QuantityTextBox" Text="200" Width="80" VerticalContentAlignment="Center"/>
                    <Button Content="全仓" Margin="5,0,0,0" Padding="10,0" Click="BtnFullPosition_Click" ToolTip="根据下方持仓总数自动填入" Background="#EEE"/>
                    <Button Content="半仓" Margin="5,0,0,0" Padding="10,0" Click="BtnHalfPosition_Click" Background="#EEE"/>
                    <Button Content="1/3合" Margin="5,0,0,0" Padding="5,0" Click="BtnOneThirdPosition_Click" Background="#EEE"/>
                </StackPanel>

                <TextBlock Text="预期盈利:" Grid.Row="3" VerticalAlignment="Center" Margin="0,0,10,5" Foreground="#007ACC" FontWeight="Bold"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBox x:Name="TargetProfitTextBox" Text="100" Width="80" VerticalContentAlignment="Center"/>
                    <ComboBox x:Name="ProfitModeComboBox" Margin="5,0,0,0" SelectedIndex="0" VerticalContentAlignment="Center" Width="100">
                        <ComboBoxItem Content="固定金额(元)"/>
                        <ComboBoxItem Content="收益率(%)"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="最大承受亏损(元):" Grid.Row="4" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Brown" FontWeight="Bold"/>
                <TextBox x:Name="MaxLossTextBox" Text="100" Grid.Row="4" Grid.Column="1" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 三、操作按钮区 -->
        <Grid Grid.Row="3" Grid.Column="0" Margin="0,0,10,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <Button Content="计算保本价及目标获利价" Padding="10" 
                    Background="#007ACC" Foreground="White" FontSize="14" FontWeight="Bold"
                    Click="CalculateButton_Click"/>
            <Button Content="一键清空" Grid.Column="1" Margin="10,0,0,0" Padding="10" 
                    Background="#E51400" Foreground="White" FontSize="14" FontWeight="Bold"
                    Click="ResetButton_Click" ToolTip="清空输入框但保留费率设置"/>
        </Grid>

        <!-- 四、计算结果区 -->
        <GroupBox Header="计算结果" Grid.Row="0" Grid.Column="1" Margin="10,0,0,10" Padding="10" BorderBrush="#007ACC" BorderThickness="2">
            <StackPanel>
                <TextBlock Text="一买一卖总手续费预估: " FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="TotalFeeTextBlock" Text="--- 元" FontSize="18" Foreground="#555" Margin="0,0,0,2"/>
                <TextBlock x:Name="FeeDetailTextBlock" Text="(明细：佣金 --- 元 , 印花税 --- 元 , 过户费 --- 元)" FontSize="12" Foreground="#888" Margin="0,0,0,10"/>

                <TextBlock Text="保本目标价 (仅够交手续费): " FontSize="14" FontWeight="SemiBold"/>
                <TextBlock x:Name="TargetPriceTextBlock" Text="--- 元" FontSize="20" Foreground="#E51400" Margin="0,0,0,10"/>

                <TextBlock Text="🎯 达成预期净利的目标价: " FontSize="15" FontWeight="Bold"/>
                <TextBlock x:Name="ProfitTargetPriceTextBlock" Text="--- 元" FontSize="24" Foreground="#008A00" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="⚠️ 必须止损的离场价: " FontSize="15" FontWeight="Bold" Foreground="Brown"/>
                <TextBlock x:Name="StopLossPriceTextBlock" Text="--- 元" FontSize="24" Foreground="Brown" FontWeight="Bold"/>
            </StackPanel>
        </GroupBox>
        
        <!-- 五、持仓分析区 (选填) -->
        <GroupBox Header="持仓及降本分析 (选填参数)" Grid.Row="1" Grid.Column="1" Margin="10,0,0,10" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="目前持仓均价 (元):" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="CostPriceTextBox" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="持有股份总数 (股):" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="HoldingQuantityTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="当前现价 (元):" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,10,5"/>
                <TextBox x:Name="CurrentPriceTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5" VerticalContentAlignment="Center" ToolTip="留空则默认按上方首笔‘交易单价’估算盈亏"/>

                <TextBlock Text="当前浮动盈亏(基于现价):" Grid.Row="3" VerticalAlignment="Center" Margin="0,10,10,5" Foreground="#555"/>
                <TextBlock x:Name="HoldingPnLTextBlock" Text="---" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,10,0,5" FontWeight="Bold"/>

                <TextBlock Text="若按目标价完成本次做T:" Grid.Row="4" VerticalAlignment="Center" Margin="0,0,10,5" FontWeight="SemiBold"/>
                <TextBlock Text="⬇️ 做T成功后全新持仓成本:" Grid.Row="5" VerticalAlignment="Center" Margin="0,5,10,0" Foreground="#007ACC" FontWeight="Bold"/>
                <TextBlock x:Name="NewCostPriceTextBlock" Text="---" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,5,0,0" FontSize="16" Foreground="#007ACC" FontWeight="Bold"/>
            </Grid>
        </GroupBox>

        <!-- 错误提示文本 -->
        <TextBlock x:Name="ErrorTextBlock" Grid.Row="2" Grid.Column="1" Margin="10,0,0,10" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- 历史交易记录 -->
        <GroupBox Header="历史做T记录" Grid.Row="3" Grid.Column="1" Grid.RowSpan="2" Margin="10,0,0,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Content="保存当前计算结果" Click="SaveRecordButton_Click" Background="#EEE" Margin="0,0,0,5" Padding="5"/>
                <ListBox x:Name="HistoryListBox" Grid.Row="1" AlternationCount="2"/>
                <Button Content="清空历史记录" Click="ClearHistoryButton_Click" Grid.Row="2" Background="#EEE" Margin="0,5,0,0" Padding="5"/>
            </Grid>
        </GroupBox>

    </Grid>
    </ScrollViewer>
</Window>
